{
  "manifest_version": 3,
  "name": "YouTube Shorts Auto-Scroller",
  "version": "1.4",
  "description": "Auto-scroll YouTube Shorts with a draggable play/pause button (no accidental toggles) and best-effort background support.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "author": "Abdullah Anbar",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_title": "YouTube Shorts Auto-Scroller",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "alarms",
    "activeTab"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-shorts-scroller@example.com"
    }
  }
}
